    {
      "description": "(Right)Alt => F19(한/영) (입력소스 설정에서 단축키 F19 등록 필요)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "right_command" },
          "to": [ { "key_code": "f19", "repeat": false } ],
          "conditions": [ { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.parallels\\.desktop\\.console$", "^com\\.microsoft\\.rdc\\.macos$", "^com\\.vmware\\.horizon$", "^com\\.citrix\\.receiver\\.icaviewer\\.mac$"] } ]
        }
      ]
    },
